# 说明：
# 1. 当前项目会自动读取 `.env.example` 和 `.env`
# 2. 部署前建议先复制为 `.env` 再修改
# 3. 如果 `data/db.json` 已存在，管理员账号密码以库里现有数据为准

# 基础站点
PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
CORS_ALLOWED_ORIGINS=http://localhost:8787,http://127.0.0.1:8787,http://localhost:5173,http://127.0.0.1:5173

# 管理后台
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
ADMIN_SESSION_ABSOLUTE_TTL_MS=43200000
ADMIN_SESSION_IDLE_TTL_MS=7200000
ADMIN_LOGIN_WINDOW_MS=900000
ADMIN_LOGIN_LOCKOUT_MS=900000
ADMIN_LOGIN_MAX_FAILURES=5

# 支付配置
PAYMENT_MODE=manual_review
PAYMENT_CHANNEL_LABEL=支付宝 / 微信人工审核
# PAYMENT_ACCOUNT_NAME=
# PAYMENT_ACCOUNT_NO=
# PAYMENT_QR_CODE_URL=
PAYMENT_INSTRUCTIONS=下单后提交付款备注或流水号，管理员审核通过后自动发放或充值。

# 上游模式优先级：
# SUB2API > GATEWAY > NEWAPI > OPENAI

# -------------------------
# Sub2API 模式
# -------------------------
# SUB2API_BASE_URL=http://127.0.0.1:8794
# SUB2API_ADMIN_API_KEY=
# SUB2API_ADMIN_EMAIL=
# SUB2API_ADMIN_PASSWORD=
# SUB2API_DEFAULT_GROUPS=openai:premium,claude:premium,gemini:premium,antigravity:premium
# SUB2API_DEFAULT_PROVIDER_GROUP=premium

# -------------------------
# 自研网关模式
# -------------------------
# GATEWAY_ACCOUNTS_FILE=./data/gateway-accounts.json
# GATEWAY_ACCOUNTS_JSON=

# -------------------------
# New API 模式
# -------------------------
# NEWAPI_BASE_URL=http://127.0.0.1:3000
# NEWAPI_ADMIN_ACCESS_TOKEN=
# NEWAPI_ADMIN_USER_ID=
# NEWAPI_ADMIN_USERNAME=
# NEWAPI_ADMIN_PASSWORD=
# NEWAPI_USER_GROUP=default
# NEWAPI_TOKEN_GROUP=

# -------------------------
# 单一 OpenAI 兼容上游
# -------------------------
# OPENAI_BASE_URL=https://your-upstream.example.com/v1
# OPENAI_API_KEY=sk-xxxx
